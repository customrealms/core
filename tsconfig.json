{
	"compileOnSave": false,
	"compilerOptions": {
		"strict": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"sourceMap": true,
		"declaration": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"importHelpers": true,
		"target": "ES6",
		"lib": ["es2018"],
		"types": ["@customrealms/runtime-types"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts"]
}
