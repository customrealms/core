{
	"compileOnSave": false,
	"compilerOptions": {
		"strict": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"sourceMap": true,
		"declaration": true,
		"module": "esnext",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"importHelpers": true,
		"target": "es5",
		"lib": ["es2018", "dom"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts"]
}
